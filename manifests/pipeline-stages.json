{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "pipeline_id": "research-to-manuscript-v1",
  "description": "Research-to-Manuscript Workflow — MVP 主链",
  "version": "1.3.1",
  "stages": [
    {
      "id": "part1",
      "name": "Collect Sources",
      "description": "文献检索、下载、真实性校验与资料库构建",
      "inputs": [
        "用户结构化 intake",
        "manifests/source-policy.json",
        "相关性策略配置"
      ],
      "canonical_artifacts": [
        "raw-library/metadata.json",
        "outputs/part1/authenticity_report.json"
      ],
      "all_outputs": [
        "outputs/part1/intake_request.md",
        "outputs/part1/intake_template.json",
        "outputs/part1/workspace_manifest.json",
        "outputs/part1/search_plan.json",
        "outputs/part1/supplementary_sources_task.md",
        "outputs/part1/retrieval_log.json",
        "outputs/part1/metadata_records.json",
        "outputs/part1/accepted_sources.json",
        "outputs/part1/excluded_sources_log.json",
        "outputs/part1/source_quota_report.json",
        "outputs/part1/download_manifest.json",
        "outputs/part1/downloaded_papers_table.csv",
        "outputs/part1/downloaded_papers_table.md",
        "outputs/part1/authenticity_report.json",
        "raw-library/metadata.json",
        "raw-library/papers/",
        "raw-library/web-archives/",
        "raw-library/normalized/",
        "raw-library/provenance/",
        "workspaces/ws_NNN/workspace_manifest.json",
        "workspaces/ws_NNN/outputs/part1/intake.json"
      ],
      "retrieval_pipeline": [
        "intake_request",
        "workspace_bootstrap",
        "intake_normalization",
        "query_planning",
        "source_routing",
        "multi_source_retrieval",
        "relevance_scoring",
        "deduplication",
        "authenticity_verification",
        "local_download",
        "normalization",
        "provenance_capture"
      ],
      "human_gates": [
        {
          "id": "intake_confirmed",
          "description": "研究主题与结构化 intake 关键参数已由用户确认",
          "blocking": true,
          "position": "before_query_planning_and_retrieval"
        }
      ],
      "completion_gate": {
        "required_artifacts": [
          "raw-library/metadata.json",
          "outputs/part1/authenticity_report.json"
        ],
        "required_checks": [
          "检索计划已生成",
          "已确认 intake 的隔离 workspace 已创建或复用",
          "优先来源策略已执行（CNKI 优先）",
          "相关性评估已完成",
          "真实性校验通过",
          "本地资料库落地完成",
          "accepted sources 满足 40 篇配额、CNKI 60%-70% 与英文期刊至少 5 篇",
          "已下载论文清单已生成在 outputs/part1/"
        ]
      }
    },
    {
      "id": "part2",
      "name": "Build Research Wiki",
      "description": "将 raw-library 转换为可检索、可维护的 research wiki，建立研究证据层与写作规范层",
      "inputs": [
        "raw-library/metadata.json",
        "outputs/part1/authenticity_report.json",
        "导师 PPT / 课程资料 / 中文学术写作规范（可选）"
      ],
      "canonical_artifacts": [
        "research-wiki/index.json"
      ],
      "all_outputs": [
        "research-wiki/pages/",
        "research-wiki/index.json",
        "research-wiki/contradictions_report.json",
        "research-wiki/update_log.json",
        "writing-policy/rules/",
        "writing-policy/style_guides/",
        "writing-policy/source_index.json"
      ],
      "wiki_maintenance_operations": [
        "update",
        "reconcile",
        "lint",
        "health_check"
      ],
      "human_gates": [],
      "completion_gate": {
        "required_artifacts": [
          "research-wiki/index.json"
        ],
        "required_checks": [
          "wiki 页面生成完成",
          "index 可用",
          "来源映射完整（所有页面有 source_ids）",
          "contradictions / health check 通过基本门槛",
          "writing policy 层已建立"
        ]
      }
    },
    {
      "id": "part3",
      "name": "Generate Argument Trees",
      "description": "生成 3 份候选论证树，提供比较，保留人工选择，锁定 canonical argument tree",
      "inputs": [
        "research-wiki/index.json",
        "research-wiki/pages/",
        "writing-policy/",
        "研究目标与主题范围"
      ],
      "canonical_artifacts": [
        "outputs/part3/argument_tree.json"
      ],
      "all_outputs": [
        "outputs/part3/argument_seed_map.json",
        "outputs/part3/candidate_argument_trees/",
        "outputs/part3/refined_candidate_argument_trees/",
        "outputs/part3/refined_candidate_argument_trees/refinement_summary.json",
        "outputs/part3/candidate_comparison.json",
        "outputs/part3/argument_quality_report.json",
        "outputs/part3/human_selection_feedback.json",
        "outputs/part3/argument_tree.json"
      ],
      "candidate_count": 3,
      "human_gates": [
        {
          "id": "argument_tree_selected",
          "description": "候选 argument tree 已由用户选定并锁定",
          "blocking": true,
          "position": "before_canonical_lock"
        }
      ],
      "completion_gate": {
        "required_artifacts": [
          "outputs/part3/argument_tree.json",
          "outputs/part3/candidate_comparison.json",
          "outputs/part3/human_selection_feedback.json"
        ],
        "required_checks": [
          "3 份候选 argument tree 齐备",
          "comparison 齐备（含各候选优缺点）",
          "human feedback 齐备",
          "canonical argument tree 已锁定（locked_at 已写入）"
        ]
      }
    },
    {
      "id": "part4",
      "name": "Generate Outline",
      "description": "基于 argument tree + wiki + writing policy + 参考案例生成 canonical paper outline",
      "inputs": [
        "outputs/part3/argument_tree.json",
        "research-wiki/index.json",
        "research-wiki/pages/",
        "writing-policy/",
        "中文论文参考案例（可选）",
        "章节结构 rubric（可选）"
      ],
      "canonical_artifacts": [
        "outputs/part4/paper_outline.json"
      ],
      "all_outputs": [
        "outputs/part4/paper_outline.json",
        "outputs/part4/outline_rationale.json",
        "outputs/part4/reference_alignment_report.json"
      ],
      "outline_generation_strategy": "argument_tree + research_wiki + writing_policy + reference_cases",
      "training_dependency": false,
      "human_gates": [],
      "completion_gate": {
        "required_artifacts": [
          "outputs/part4/paper_outline.json",
          "outputs/part4/outline_rationale.json",
          "outputs/part4/reference_alignment_report.json"
        ],
        "required_checks": [
          "canonical outline 已生成",
          "outline 与 argument tree 对齐",
          "reference alignment report 可用",
          "Part 4 completion gate 通过后可自动进入 Part 5"
        ]
      }
    },
    {
      "id": "part5",
      "name": "Draft + Review + Revision MVP",
      "description": "基于 canonical outline 自动生成写作输入包、保守正文 scaffold、结构化 review、revision、本地产物与 Part 6 readiness decision",
      "inputs": [
        "outputs/part4/paper_outline.json",
        "outputs/part4/outline_rationale.json",
        "outputs/part4/reference_alignment_report.json",
        "outputs/part3/argument_tree.json",
        "research-wiki/index.json",
        "research-wiki/pages/",
        "writing-policy/source_index.json",
        "raw-library/metadata.json"
      ],
      "canonical_artifacts": [
        "outputs/part5/manuscript_v2.md",
        "outputs/part5/review_matrix.json",
        "outputs/part5/review_report.md",
        "outputs/part5/revision_log.json",
        "outputs/part5/part6_readiness_decision.json"
      ],
      "all_outputs": [
        "outputs/part5/chapter_briefs/",
        "outputs/part5/case_analysis_templates/",
        "outputs/part5/claim_evidence_matrix.json",
        "outputs/part5/citation_map.json",
        "outputs/part5/figure_plan.json",
        "outputs/part5/open_questions.json",
        "outputs/part5/manuscript_v1.md",
        "outputs/part5/review_matrix.json",
        "outputs/part5/review_report.md",
        "outputs/part5/review_summary.md",
        "outputs/part5/claim_risk_report.json",
        "outputs/part5/citation_consistency_precheck.json",
        "outputs/part5/revision_log.json",
        "outputs/part5/manuscript_v2.md",
        "outputs/part5/part6_readiness_decision.json"
      ],
      "part5_strategy": "contract-first staged drafting with explicit research debt carryover",
      "automation_flow": [
        "part5_prep",
        "part5_draft",
        "part5_review",
        "part5_revise"
      ],
      "training_dependency": false,
      "human_gates": [],
      "completion_gate": {
        "required_artifacts": [
          "outputs/part5/manuscript_v2.md",
          "outputs/part5/review_matrix.json",
          "outputs/part5/review_report.md",
          "outputs/part5/revision_log.json",
          "outputs/part5/part6_readiness_decision.json"
        ],
        "required_checks": [
          "写作输入包已自动生成",
          "manuscript_v1 已生成",
          "结构化 review 与 citation precheck 齐备",
          "review_report.md 已生成在 outputs/part5/",
          "revision_log 与 manuscript_v2 齐备",
          "manuscript_v2.md 已生成在 outputs/part5/",
          "critical blocker 已登记，不得静默吞掉",
          "Part 6 readiness decision 只表达 readiness，不自动推进 Part 6"
        ]
      }
    },
    {
      "id": "part6",
      "name": "Finalize MVP",
      "description": "Part 6 MVP：通过 runtime agent、skill 与 part6-finalize action 生成最终稿、最终审计、交付包 manifest 与人工最终决策记录；不声明 submission action",
      "inputs": [
        "outputs/part5/manuscript_v2.md",
        "outputs/part5/part6_readiness_decision.json",
        "outputs/part5/claim_risk_report.json",
        "outputs/part5/citation_consistency_precheck.json",
        "outputs/part5/claim_evidence_matrix.json",
        "outputs/part5/citation_map.json",
        "raw-library/metadata.json",
        "research-wiki/index.json",
        "writing-policy/source_index.json"
      ],
      "canonical_artifacts": [
        "outputs/part6/final_manuscript.md",
        "outputs/part6/claim_risk_report.json",
        "outputs/part6/citation_consistency_report.json",
        "outputs/part6/submission_package_manifest.json",
        "outputs/part6/final_readiness_decision.json"
      ],
      "all_outputs": [
        "outputs/part6/final_manuscript.md",
        "outputs/part6/final_abstract.md",
        "outputs/part6/final_keywords.json",
        "outputs/part6/submission_checklist.md",
        "outputs/part6/claim_risk_report.json",
        "outputs/part6/citation_consistency_report.json",
        "outputs/part6/submission_package_manifest.json",
        "outputs/part6/final_readiness_decision.json"
      ],
      "part6_scope": [
        "finalize_gate_foundation",
        "final_package_contract",
        "human_final_decision"
      ],
      "implementation_boundary": {
        "runtime_agent_declared": true,
        "skill_declared": true,
        "finalize_action_declared": true,
        "submission_action_declared": false
      },
      "automation_flow": [
        "part6_finalize",
        "part6_audit_claim",
        "part6_audit_citation",
        "part6_package_draft",
        "part6_decide",
        "part6_package_final"
      ],
      "human_gates": [
        {
          "id": "part6_finalization_authorized",
          "description": "用户已授权进入 Part 6 finalization gate foundation",
          "blocking": true,
          "position": "before_final_package_contract_check"
        },
        {
          "id": "part6_final_decision_confirmed",
          "description": "最终 readiness verdict 与 submission package manifest 已由用户确认",
          "blocking": true,
          "position": "before_part6_completion"
        }
      ],
      "completion_gate": {
        "required_artifacts": [
          "outputs/part6/final_manuscript.md",
          "outputs/part6/claim_risk_report.json",
          "outputs/part6/citation_consistency_report.json",
          "outputs/part6/submission_package_manifest.json",
          "outputs/part6/final_readiness_decision.json"
        ],
        "required_checks": [
          "Part 1-5 gates completed",
          "Part 5 readiness verdict is not blocked",
          "Part 5 handoff fingerprint has not drifted",
          "citation and evidence allowlist pass",
          "submission package manifest and final readiness verdict are consistent",
          "final decision human confirmation recorded",
          "no submission action is performed or authorized"
        ]
      }
    }
  ],
  "deferred_stages": [],
  "global_state_requirements": {
    "state_file": "runtime/state.json",
    "required_fields": [
      "current_stage",
      "stage_started_at",
      "stage_completed_at",
      "canonical_artifact_status",
      "last_failure_location",
      "repair_log",
      "human_decision_log"
    ],
    "on_state_corruption": "block_and_report — 不得静默重置"
  }
}
