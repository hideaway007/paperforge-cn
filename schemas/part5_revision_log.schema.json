{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "part5_revision_log",
  "title": "Part 5 Revision Log",
  "type": "object",
  "required": ["schema_version", "generated_at", "source_review_ref", "revisions", "residual_risks"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "source_review_ref": {
      "type": "string",
      "const": "outputs/part5/review_matrix.json"
    },
    "revisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["revision_id", "review_id", "action", "status"],
        "additionalProperties": true,
        "properties": {
          "revision_id": {"type": "string", "minLength": 1},
          "review_id": {"type": "string", "minLength": 1},
          "action": {"type": "string", "minLength": 1},
          "review_dimension": {"type": "string"},
          "status": {
            "type": "string",
            "enum": ["planned", "applied", "blocked", "deferred"]
          }
        }
      }
    },
    "residual_risks": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
