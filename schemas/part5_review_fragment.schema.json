{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "part5_review_fragment",
  "title": "Part 5 Review Fragment",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "dimension",
    "manuscript_ref",
    "fragment_ref",
    "reviews"
  ],
  "additionalProperties": true,
  "properties": {
    "schema_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "dimension": {
      "type": "string",
      "enum": ["structure", "argument", "evidence", "citation", "writing_policy"]
    },
    "manuscript_ref": {
      "type": "string",
      "const": "outputs/part5/manuscript_v1.md"
    },
    "fragment_ref": {
      "type": "string",
      "pattern": "^outputs/part5/review_fragments/.+_review\\.json$"
    },
    "reviews": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["review_id", "dimension", "severity", "finding", "status", "claim_ids"],
        "additionalProperties": true,
        "anyOf": [
          {"required": ["source_refs"]},
          {"required": ["evidence_refs"]}
        ],
        "properties": {
          "review_id": {"type": "string", "minLength": 1},
          "dimension": {
            "type": "string",
            "enum": ["structure", "argument", "evidence", "citation", "writing_policy"]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "finding": {"type": "string", "minLength": 1},
          "claim_ids": {
            "type": "array",
            "items": {"type": "string"}
          },
          "source_refs": {
            "type": "array",
            "items": {"type": "object", "additionalProperties": true}
          },
          "evidence_refs": {
            "type": "array",
            "items": {"type": "object", "additionalProperties": true}
          },
          "status": {
            "type": "string",
            "enum": ["registered", "unresolved", "resolved", "mitigated", "downgraded"]
          }
        }
      }
    }
  }
}
